{
  "name": "mango-king-server",
  "version": "1.0.0",
  "description": "Mango King Ratnagiri — REST API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev":              "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build":            "tsc",
    "start":            "node dist/index.js",
    "db:generate":      "prisma generate",
    "db:push":          "prisma db push",
    "db:migrate":       "prisma migrate dev",
    "db:migrate:prod":  "prisma migrate deploy",
    "db:studio":        "prisma studio",
    "db:seed":          "ts-node --project scripts/tsconfig.json scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client":   "^5.8.0",
    "axios":            "^1.6.5",
    "bcryptjs":         "^2.4.3",
    "compression":      "^1.7.4",
    "cors":             "^2.8.5",
    "date-fns":         "^3.3.1",
    "dotenv":           "^16.4.1",
    "express":          "^4.18.2",
    "express-rate-limit":"^7.2.0",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "morgan":           "^1.10.0",
    "multer":           "^1.4.5-lts.1",
    "razorpay":         "^2.9.2",
    "sharp":            "^0.33.2",
    "zod":              "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":   "^2.4.6",
    "@types/compression":"^1.7.5",
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/jsonwebtoken":"^9.0.5",
    "@types/morgan":     "^1.9.9",
    "@types/multer":     "^1.4.11",
    "@types/node":       "^20.11.5",
    "prisma":            "^5.8.0",
    "ts-node":           "^10.9.2",
    "ts-node-dev":       "^2.0.0",
    "typescript":        "^5.3.3"
  }
}
